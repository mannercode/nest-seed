{
    "name": "nest-mono",
    "version": "0.0.1",
    "private": true,
    "comments": {
        "apps:*": "App stack scripts for this repo (root-level docker compose)."
    },
    "scripts": {
        "start": "node _output/dist/index.js",
        "build": "nest build -b webpack",
        "debug": "nest start --watch",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --no-cache --coverage",
        "test:e2e": "npm run apps:reset && bash tests/e2e/run-all.sh && npm run apps:down",
        "format": "eslint src/ --fix && prettier --write src/",
        "lint": "tsc -p tsconfig.json --noEmit && eslint src/ --max-warnings=0 && prettier --check src/",
        "apps:down": "docker compose down -v -t 0 --remove-orphans",
        "apps:up": "  docker compose up -d --build",
        "apps:wait": "docker wait apps-setup && docker rm apps-setup",
        "apps:reset": "npm run apps:down && npm run apps:up && npm run apps:wait"
    },
    "dependencies": {
        "@mannercode/common": "^2.0.0",
        "@mannercode/testing": "^2.0.0",
        "@aws-sdk/client-s3": "^3.1023.0",
        "@aws-sdk/s3-presigned-post": "^3.1023.0",
        "@aws-sdk/s3-request-presigner": "^3.1023.0",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/common": "^11.1.17",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.17",
        "@nestjs/event-emitter": "^3.0.1",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/mapped-types": "^2.1.1",
        "@nestjs/mongoose": "^11.0.4",
        "@nestjs/platform-express": "^11.1.17",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/terminus": "^11.1.1",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.72.1",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.4",
        "compression": "^1.8.1",
        "express": "^5.2.1",
        "ioredis": "^5.10.1",
        "joi": "^18.1.2",
        "mongoose": "^9.3.3",
        "mongoose-lean-virtuals": "^2.1.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.17",
        "@nestjs/schematics": "^11.0.10",
        "@nestjs/testing": "^11.1.17",
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^24",
        "@types/superagent": "^8.1.9",
        "eslint": "^10.1.0",
        "eslint-plugin-allowed-dependencies": "^2.1.0",
        "eslint-plugin-jest": "^29.15.1",
        "eslint-plugin-perfectionist": "^5.8.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.4.0",
        "jest": "^30.3.0",
        "prettier": "^3.8.1",
        "superagent": "^10.3.0",
        "ts-jest": "^29.4.9",
        "ts-loader": "^9.5.7",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0"
    },
    "overrides": {
        "lodash": "^4.18.0"
    }
}
