# Docker image tags
MONGO_IMAGE=mongo:8.2.3
REDIS_IMAGE=redis:8.4-alpine
NATS_IMAGE=nats:2.12-alpine
MINIO_IMAGE=minio/minio:latest
TEMPORAL_IMAGE=temporalio/auto-setup:1.25

# MongoDB
MONGO_REPLICA_SET=mongo
MONGO_USERNAME=mongouser
MONGO_PASSWORD=mongopass
MONGO_DATABASE=mongodb
MONGO_HOST1=host.docker.internal
MONGO_PORT1=27017
MONGO_HOST2=host.docker.internal
MONGO_PORT2=27018
MONGO_HOST3=host.docker.internal
MONGO_PORT3=27019

# Redis
REDIS_HOST1=host.docker.internal
REDIS_PORT1=6379
REDIS_HOST2=host.docker.internal
REDIS_PORT2=6380
REDIS_HOST3=host.docker.internal
REDIS_PORT3=6381
REDIS_HOST4=host.docker.internal
REDIS_PORT4=6382
REDIS_HOST5=host.docker.internal
REDIS_PORT5=6383
REDIS_HOST6=host.docker.internal
REDIS_PORT6=6384

# NATS
NATS_CLUSTER=nats-cluster
NATS_HOST1=host.docker.internal
NATS_PORT1=4222
NATS_HOST2=host.docker.internal
NATS_PORT2=4223
NATS_HOST3=host.docker.internal
NATS_PORT3=4224

# MinIO (S3)
S3_ENDPOINT=http://host.docker.internal:9000
S3_REGION=us-east-1
S3_BUCKET=nest-bucket
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_FORCE_PATH_STYLE=true

# Temporal
TEMPORAL_HOST=host.docker.internal
TEMPORAL_PORT=7233
TEMPORAL_DB_PORT=5432
TEMPORAL_UI_PORT=8233
TEMPORAL_NAMESPACE=default
