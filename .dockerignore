# Whitelist approach: exclude everything, then allow only what's needed.
# All patterns MUST use / anchor — without it, patterns match at any depth,
# causing unintended files (e.g. libs/testing/package.json) to leak into the build context.
*

!/package.json
!/tsconfig.json

!/libs/tsconfig.json
!/libs/*/package.json
!/libs/*/tsconfig.build.json
!/libs/*/src/

# testing is not used by apis, so exclude it
libs/testing
libs/testing/**

!/apis/jest.*.js
!/apis/*/package.json
!/apis/*/webpack.config.js
!/apis/*/tsconfig.json
!/apis/*/tsconfig.build.json
!/apis/*/nest-cli.json
!/apis/*/src/
!/apis/*/scripts/

**/node_modules
**/_output
**/__tests__
