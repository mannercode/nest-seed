# Whitelist approach: exclude everything, then allow only what's needed.
# All patterns MUST use / anchor — without it, patterns match at any depth,
# causing unintended files (e.g. libs/testing/package.json) to leak into the build context.
*

!/package.json
!/package-lock.json
!/tsconfig.json

!/libs/tsconfig.json
!/libs/*/package.json
!/libs/*/tsconfig.build.json
!/libs/*/src/

!/apps/*/package.json
!/apps/*/webpack.config.js
!/apps/*/tsconfig.json
!/apps/*/tsconfig.build.json
!/apps/*/nest-cli.json
!/apps/*/src/
!/apps/*/scripts/
!/apps/*/jest.*.js

**/node_modules
**/_output
**/__tests__
