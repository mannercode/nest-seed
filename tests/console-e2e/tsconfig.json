{
    "compilerOptions": {
        "target": "ES2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "lib": ["dom", "esnext"],
        "types": ["node"]
    },
    "include": ["tests/**/*", "playwright.config.ts"]
}
