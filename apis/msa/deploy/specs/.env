SERVER_URL=http://localhost:3100

# This e2e folder doubles as living documentation, so portability comes first.
# SHA-256 utilities vary by OS, so we keep precomputed values here.
# e2e 폴더는 문서를 겸하므로 이식성을 우선한다.
# SHA-256 도구는 OS마다 다를 수 있어 미리 계산한 값도 함께 둔다.
ASSET_IMAGE_PATH=./assets/image.png
ASSET_IMAGE_ORIGINAL_NAME=image.png
ASSET_IMAGE_SIZE=170550
ASSET_IMAGE_SHA256_BASE64=d5l1XdGa5zgerERd5V5xMR0X0mbMoZvJL1liTH1to2A=
