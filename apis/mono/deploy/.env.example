# Number of app container replicas (default: 4)
REPLICAS=4

# External port to expose (default: 3000)
LISTEN_PORT=3000

# App settings
HTTP_REQUEST_PAYLOAD_LIMIT=50mb
HTTP_PAGINATION_DEFAULT_SIZE=50

# Auth
AUTH_ACCESS_SECRET=change_me_at_least_20_chars
AUTH_ACCESS_TOKEN_EXPIRATION=30m
AUTH_REFRESH_SECRET=change_me_at_least_20_chars
AUTH_REFRESH_TOKEN_EXPIRATION=7d

# MongoDB (replica set)
MONGO_REPLICA_SET=rs0
MONGO_USERNAME=admin
MONGO_PASSWORD=password
MONGO_DATABASE=nest-mono
MONGO_HOST1=host.docker.internal
MONGO_PORT1=27017
MONGO_HOST2=host.docker.internal
MONGO_PORT2=27018
MONGO_HOST3=host.docker.internal
MONGO_PORT3=27019

# Redis (cluster)
REDIS_HOST1=host.docker.internal
REDIS_PORT1=6379
REDIS_HOST2=host.docker.internal
REDIS_PORT2=6380
REDIS_HOST3=host.docker.internal
REDIS_PORT3=6381
REDIS_HOST4=host.docker.internal
REDIS_PORT4=6382
REDIS_HOST5=host.docker.internal
REDIS_PORT5=6383
REDIS_HOST6=host.docker.internal
REDIS_PORT6=6384

# S3
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true

# Logging
LOG_DAYS_TO_KEEP=3d
LOG_FILE_LEVEL=verbose
LOG_CONSOLE_LEVEL=info
