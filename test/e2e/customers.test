#!/bin/bash
set -euo pipefail
. ./common.cfg

reset_all
create_user_and_login

TITLE "Retrieve User"
GET 200 /customers/$USER_ID \
    -H "Authorization: Bearer $ACCESS_TOKEN"

TITLE "Retrieve All Users"
GET 200 /customers \
    -H "Authorization: Bearer $ACCESS_TOKEN"

TITLE "Update User"
PATCH 200 /customers/$USER_ID \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -d '{
 "name": "new name",
 "email": "new@mail.com",
 "birthDate": "2000-01-01"
 }'

TITLE "Delete User with Specific ID"
DELETE 200 /customers/$USER_ID \
    -H "Authorization: Bearer $ACCESS_TOKEN"
