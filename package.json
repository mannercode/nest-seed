{
    "name": "nest-seed",
    "private": true,
    "license": "MIT",
    "comments": {
        "workspaces": [
            "workspaces 항목 순서 = 빌드 순서. 의존성이 먼저 오도록 유지할 것."
        ]
    },
    "workspaces": [
        "libs/temporal-sandbox",
        "libs/common",
        "libs/testing",
        "tools/*",
        "apps/*",
        "tests/*"
    ],
    "scripts": {
        "prepare": "husky",
        "build": "npm run build --workspaces --if-present",
        "clean": "git clean -fdX",
        "lint": "npm run lint --workspaces --if-present",
        "postlint": "prettier --check . && git ls-files '*.sh' | xargs -r shellcheck --severity=warning && git ls-files '*.md' | xargs -r lychee --offline --include-fragments",
        "format": "npm run format --workspaces --if-present",
        "postformat": "prettier --write .",
        "pretest": "npm run build -w libs",
        "test": "npm test --workspaces --if-present",
        "e2e": "npm run e2e -w tests/console-e2e",
        "preatoz": "npm run clean && bash infra/reset.sh && for i in 1 2 3 4 5; do npm ci && break; [ $i = 5 ] && exit 1; sleep $((i*10)); done",
        "atoz": "npm run atoz --workspaces --if-present && npm run lint && bash deploy/verify.sh",
        "postatoz": "echo '✅ ATOZ PASS'",
        "predev": "npm run build -w libs",
        "dev": "concurrently 'npm:dev:*'",
        "dev:common": "npm run dev -w libs/common",
        "dev:testing": "npm run dev -w libs/testing",
        "dev:api": "npm run dev -w apps/api",
        "dev:console": "npm run dev -w apps/console",
        "dev:user-app": "npm run dev -w apps/user-app"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "3.1085.0",
        "@aws-sdk/s3-presigned-post": "3.1085.0",
        "@aws-sdk/s3-request-presigner": "3.1085.0",
        "@commitlint/cli": "21.2.1",
        "@commitlint/config-conventional": "21.2.0",
        "@nestjs/common": "11.1.28",
        "@nestjs/config": "4.0.4",
        "@nestjs/core": "11.1.28",
        "@nestjs/jwt": "11.0.2",
        "@nestjs/mongoose": "11.0.4",
        "@nestjs/terminus": "11.1.1",
        "@nestjs/testing": "11.1.28",
        "@temporalio/client": "1.20.2",
        "@temporalio/testing": "1.20.2",
        "@temporalio/worker": "1.20.2",
        "@testcontainers/mongodb": "12.0.4",
        "@testcontainers/nats": "12.0.4",
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/node": "24",
        "@types/superagent": "8.1.10",
        "@typescript-eslint/parser": "8.63.0",
        "class-transformer": "0.5.1",
        "class-validator": "0.15.1",
        "concurrently": "10.0.3",
        "eslint": "10.7.0",
        "eslint-plugin-perfectionist": "5.10.0",
        "eslint-plugin-unused-imports": "4.4.1",
        "express": "5.2.1",
        "globals": "17.7.0",
        "husky": "9.1.7",
        "ioredis": "5.11.1",
        "jest": "30.4.2",
        "joi": "18.2.3",
        "lint-staged": "17.0.8",
        "mongodb": "7.5.0",
        "mongoose": "9.7.4",
        "prettier": "3.9.5",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.2",
        "testcontainers": "12.0.4",
        "ts-jest": "29.4.11",
        "typescript": "7.0.2",
        "typescript-eslint": "8.63.0"
    },
    "packageManager": "npm@11.16.0",
    "engines": {
        "node": ">=24"
    }
}
