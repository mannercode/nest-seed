{
    "name": "nest-msa",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "start": "node _output/dist/${TARGET_APP}/index.js",
        "build": "nest build ${TARGET_APP} -b webpack",
        "debug": "nest start ${TARGET_APP} --watch",
        "test": "bash scripts/run-test.sh all 1",
        "test:e2e": "bash test/e2e/run.sh",
        "prettier": "prettier -w 'src/**/*.{js,jsx,ts,tsx}'",
        "lint": "prettier -c 'src/**/*.{js,jsx,ts,tsx}' && eslint src/ --max-warnings=0"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "prettier --write",
            "eslint"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.940.0",
        "@aws-sdk/s3-request-presigner": "^3.940.0",
        "@nestjs-modules/ioredis": "^2.0.2",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/common": "^11.1.9",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.1.9",
        "@nestjs/event-emitter": "^3.0.1",
        "@nestjs/jwt": "^11.0.1",
        "@nestjs/mapped-types": "^2.1.0",
        "@nestjs/microservices": "^11.1.9",
        "@nestjs/mongoose": "^11.0.3",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.9",
        "@nestjs/terminus": "^11.0.0",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.65.0",
        "chalk": "5.6.2",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "compression": "^1.8.1",
        "express": "^5.1.0",
        "ioredis": "^5.8.2",
        "joi": "^18.0.2",
        "lodash": "^4.17.21",
        "mongoose": "^8.20.1",
        "nats": "^2.29.3",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "winston": "^3.18.3",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.13",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/testing": "^11.1.9",
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.5",
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.17.21",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.10.1",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/superagent": "^8.1.9",
        "@typescript-eslint/eslint-plugin": "^8.48.0",
        "@typescript-eslint/parser": "^8.48.0",
        "dotenv": "^17.2.3",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "lint-staged": "^16.2.7",
        "prettier": "^3.7.1",
        "source-map-support": "^0.5.21",
