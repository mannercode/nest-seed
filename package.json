{
    "name": "nest-seed",
    "private": true,
    "workspaces": [
        "libs/*",
        "apps/*"
    ],
    "scripts": {
        "build": "turbo run build --filter='./libs/*'",
        "clean": "turbo run clean",
        "lint": "turbo run lint --filter='./libs/*'",
        "test": "cd libs && NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
        "format": "prettier --write \"libs/*/src/**/*.ts\"",
        "changeset:add": "changeset add",
        "changeset:version": "changeset version",
        "changeset:publish": "npm run build && changeset publish"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "^3.1024.0",
        "@aws-sdk/s3-presigned-post": "^3.1024.0",
        "@aws-sdk/s3-request-presigner": "^3.1024.0",
        "@changesets/cli": "^2.30.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@nestjs/common": "^11.1.18",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.18",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/microservices": "^11.1.18",
        "@nestjs/mongoose": "^11.0.4",
        "@nestjs/terminus": "^11.1.1",
        "@nestjs/testing": "^11.1.18",
        "@temporalio/client": "^1.15.0",
        "@temporalio/testing": "^1.15.0",
        "@temporalio/worker": "^1.15.0",
        "@testcontainers/mongodb": "^11.13.0",
        "@testcontainers/nats": "^11.13.0",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^24",
        "@types/superagent": "^8.1.9",
        "@typescript-eslint/parser": "^8.58.0",
        "class-transformer": "^0.5.1",
        "class-validator": "0.14.4",
        "eslint": "^10.2.0",
        "eslint-plugin-perfectionist": "^5.8.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "express": "^5.2.1",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "ioredis": "^5.10.1",
        "jest": "^30.3.0",
        "joi": "^18.1.2",
        "lint-staged": "^16.4.0",
        "mongodb": "^7.1.1",
        "mongoose": "^9.4.1",
        "prettier": "^3.8.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "testcontainers": "^11.13.0",
        "ts-jest": "^29.4.9",
        "turbo": "^2.9.3",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0"
    },
    "overrides": {
        "class-validator": "0.14.4",
        "lodash": "^4.18.0"
    },
    "packageManager": "npm@11.12.1"
}
