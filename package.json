{
    "name": "nest-seed",
    "private": true,
    "workspaces": [
        "libs/*",
        "apps/*"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "clean": "npm run clean --workspaces --if-present && git clean -fdX",
        "lint": "npm run lint --workspaces --if-present",
        "format": "npm run format --workspaces --if-present",
        "test": "npm test --workspaces --if-present",
        "atoz": "npm run clean && npm install && npm run atoz --workspaces --if-present"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "3.1033.0",
        "@aws-sdk/s3-presigned-post": "3.1033.0",
        "@aws-sdk/s3-request-presigner": "3.1033.0",
        "@commitlint/cli": "20.5.0",
        "@commitlint/config-conventional": "20.5.0",
        "@nestjs/common": "11.1.19",
        "@nestjs/config": "4.0.4",
        "@nestjs/core": "11.1.19",
        "@nestjs/jwt": "11.0.2",
        "@nestjs/microservices": "11.1.19",
        "@nestjs/mongoose": "11.0.4",
        "@nestjs/terminus": "11.1.1",
        "@nestjs/testing": "11.1.19",
        "@temporalio/client": "1.16.0",
        "@temporalio/testing": "1.16.0",
        "@temporalio/worker": "1.16.0",
        "@testcontainers/mongodb": "11.14.0",
        "@testcontainers/nats": "11.14.0",
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/node": "24",
        "@types/superagent": "8.1.9",
        "@typescript-eslint/parser": "8.59.0",
        "class-transformer": "0.5.1",
        "class-validator": "0.15.1",
        "eslint": "10.2.1",
        "eslint-plugin-perfectionist": "5.9.0",
        "eslint-plugin-unused-imports": "4.4.1",
        "express": "5.2.1",
        "globals": "17.5.0",
        "husky": "9.1.7",
        "ioredis": "5.10.1",
        "jest": "30.3.0",
        "joi": "18.1.2",
        "lint-staged": "16.4.0",
        "mongodb": "7.2.0",
        "mongoose": "9.5.0",
        "prettier": "3.8.3",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.2",
        "testcontainers": "11.14.0",
        "ts-jest": "29.4.9",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.0"
    },
    "packageManager": "npm@11.12.1"
}
