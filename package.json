{
    "name": "nest-seed",
    "private": true,
    "license": "MIT",
    "comments": {
        "workspaces": [
            "workspaces 항목 순서 = 빌드 순서. 의존성이 먼저 오도록 유지할 것."
        ]
    },
    "workspaces": [
        "libs/temporal-sandbox",
        "libs/common",
        "libs/testing",
        "tools/dev-tools",
        "tools/jest-helpers",
        "apps/*",
        "tests/*"
    ],
    "scripts": {
        "prepare": "husky",
        "build": "npm run build --workspaces --if-present",
        "build:libs": "npm run build -w libs/temporal-sandbox -w libs/common -w libs/testing",
        "clean": "npm run clean --workspaces --if-present && git clean -fdX && bash infra/reset.sh",
        "lint": "npm run lint --workspaces --if-present && npm run lint:root",
        "lint:root": "prettier --check .",
        "format": "npm run format --workspaces --if-present && prettier --write .",
        "pretest": "npm run build:libs",
        "test": "npm test --workspaces --if-present",
        "atoz": "npm run clean && npm ci && npm run lint:root && npm run atoz --workspaces --if-present && bash deploy/test.sh",
        "postatoz": "echo '✅ ATOZ PASS'",
        "predev": "npm run build:libs",
        "dev": "concurrently 'npm:dev:*'",
        "dev:common": "npm run dev -w libs/common",
        "dev:testing": "npm run dev -w libs/testing",
        "dev:api": "npm run dev -w apps/api",
        "dev:console": "npm run dev -w apps/console",
        "dev:user-app": "npm run dev -w apps/user-app"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "3.1065.0",
        "@aws-sdk/s3-presigned-post": "3.1065.0",
        "@aws-sdk/s3-request-presigner": "3.1065.0",
        "@commitlint/cli": "21.0.2",
        "@commitlint/config-conventional": "21.0.2",
        "@nestjs/common": "11.1.26",
        "@nestjs/config": "4.0.4",
        "@nestjs/core": "11.1.26",
        "@nestjs/jwt": "11.0.2",
        "@nestjs/mongoose": "11.0.4",
        "@nestjs/terminus": "11.1.1",
        "@nestjs/testing": "11.1.26",
        "@temporalio/client": "1.18.0",
        "@temporalio/testing": "1.18.0",
        "@temporalio/worker": "1.18.0",
        "@testcontainers/mongodb": "12.0.1",
        "@testcontainers/nats": "12.0.1",
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/node": "24",
        "@types/superagent": "8.1.10",
        "@typescript-eslint/parser": "8.61.0",
        "class-transformer": "0.5.1",
        "class-validator": "0.15.1",
        "concurrently": "10.0.3",
        "eslint": "10.4.1",
        "eslint-plugin-perfectionist": "5.9.0",
        "eslint-plugin-unused-imports": "4.4.1",
        "express": "5.2.1",
        "globals": "17.6.0",
        "husky": "9.1.7",
        "ioredis": "5.11.1",
        "jest": "30.4.2",
        "joi": "18.2.1",
        "lint-staged": "17.0.7",
        "mongodb": "7.3.0",
        "mongoose": "9.7.0",
        "prettier": "3.8.4",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.2",
        "testcontainers": "12.0.1",
        "ts-jest": "29.4.11",
        "typescript": "6.0.3",
        "typescript-eslint": "8.61.0"
    },
    "packageManager": "npm@11.16.0",
    "engines": {
        "node": ">=24"
    }
}
