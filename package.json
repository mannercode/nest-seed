{
    "name": "nest-msa",
    "version": "0.0.1",
    "private": true,
    "comments": {
        "scripts": {
            "TARGET_APP": [
                "TARGET_APP must match a Nest project key defined in nest-cli.json.",
                "Example: TARGET_APP=gateway npm run build"
            ],
            "apps:*": "App stack scripts for this repo (root-level docker compose).",
            "infra:*": [
                "Local shared infrastructure scripts",
                "docker compose under infra/local using '.env' and '.env.infra'."
            ]
        }
    },
    "scripts": {
        "start": "node _output/dist/${TARGET_APP}/index.js",
        "build": "nest build ${TARGET_APP} -b webpack",
        "debug": "nest start ${TARGET_APP} --watch",
        "test": "jest --no-cache --coverage --roots \"<rootDir>/${TEST_ROOT:-src}\" --collectCoverageFrom \"${TEST_ROOT:-src}/**/*.ts\"",
        "test:e2e": "npm run infra:reset && npm run apps:reset && bash tests/e2e/run-specs.sh && npm run apps:down",
        "format": "eslint src/ --fix",
        "lint": "tsc -p tsconfig.json --noEmit && eslint src/ --max-warnings=0",
        "apps:down": "docker compose down -v -t 0 --remove-orphans",
        "apps:up": "  docker compose up -d --build",
        "apps:wait": "docker wait apps-setup && docker rm apps-setup",
        "apps:reset": "npm run apps:down && npm run apps:up && npm run apps:wait",
        "infra:down": "COMPOSE_PROFILES=gui docker compose --project-directory infra/local --env-file .env --env-file .env.infra down -v -t 0 --remove-orphans",
        "infra:up": "                       docker compose --project-directory infra/local --env-file .env --env-file .env.infra up -d",
        "infra:wait": "docker wait infra-setup && docker rm infra-setup",
        "infra:reset": "npm run infra:down && npm run infra:up && npm run infra:wait",
        "infra:gui": " COMPOSE_PROFILES=gui npm run infra:reset"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.992.0",
        "@aws-sdk/s3-presigned-post": "^3.992.0",
        "@aws-sdk/s3-request-presigner": "^3.992.0",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/common": "^11.1.14",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.14",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/mapped-types": "^2.1.0",
        "@nestjs/microservices": "^11.1.14",
        "@nestjs/mongoose": "^11.0.4",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.14",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/terminus": "^11.1.0",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.69.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "compression": "^1.8.1",
        "express": "^5.2.1",
        "ioredis": "^5.9.3",
        "joi": "^18.0.2",
        "lodash": "^4.17.23",
        "mongoose": "^9.2.1",
        "mongoose-lean-virtuals": "^2.1.0",
        "nats": "^2.29.3",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.1",
        "@commitlint/config-conventional": "^20.4.1",
        "@nestjs/cli": "^11.0.16",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/testing": "^11.1.14",
        "@testcontainers/mongodb": "^11.12.0",
        "@testcontainers/nats": "^11.12.0",
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.17.23",
        "@types/node": "^24",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/superagent": "^8.1.9",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "eslint": "^10.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-allowed-dependencies": "^2.1.0",
        "eslint-plugin-jest": "^29.15.0",
        "eslint-plugin-perfectionist": "^5.6.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.3.0",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "superagent": "^10.3.0",
        "testcontainers": "^11.12.0",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3"
    }
}
