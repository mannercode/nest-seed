{
    "name": "nest-seed",
    "private": true,
    "comments": {
        "workspaces": [
            "workspaces 항목 순서 = 빌드 순서. 의존성이 먼저 오도록 유지할 것."
        ]
    },
    "workspaces": [
        "libs/common",
        "libs/testing",
        "tools/dev-tools",
        "tools/jest-helpers",
        "apps/*",
        "tests/*"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "clean": "npm run clean --workspaces --if-present && docker compose --env-file apps/api/.env -f deploy/compose.yml down -v -t 0 && git clean -fdX",
        "lint": "npm run lint --workspaces --if-present",
        "format": "npm run format --workspaces --if-present",
        "test": "npm test --workspaces --if-present",
        "atoz": "npm run clean && npm ci && npm run atoz --workspaces --if-present",
        "postatoz": "echo '✅ ATOZ PASS'",
        "dev": "concurrently 'npm:dev:*'",
        "dev:common": "npm run dev -w libs/common",
        "dev:testing": "npm run dev -w libs/testing",
        "dev:api": "npm run dev -w apps/api",
        "dev:console": "npm run dev -w apps/console",
        "list-tests:html": "mkdir -p _output && node tools/dev-tools/list-tests.js libs apps/api --html > _output/test-list.html"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "3.1045.0",
        "@aws-sdk/s3-presigned-post": "3.1045.0",
        "@aws-sdk/s3-request-presigner": "3.1045.0",
        "@commitlint/cli": "21.0.0",
        "@commitlint/config-conventional": "21.0.0",
        "@nestjs/common": "11.1.19",
        "@nestjs/config": "4.0.4",
        "@nestjs/core": "11.1.19",
        "@nestjs/jwt": "11.0.2",
        "@nestjs/microservices": "11.1.19",
        "@nestjs/mongoose": "11.0.4",
        "@nestjs/terminus": "11.1.1",
        "@nestjs/testing": "11.1.19",
        "@temporalio/client": "1.17.1",
        "@temporalio/testing": "1.17.1",
        "@temporalio/worker": "1.17.1",
        "@testcontainers/mongodb": "11.14.0",
        "@testcontainers/nats": "11.14.0",
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/node": "24",
        "@types/superagent": "8.1.9",
        "@typescript-eslint/parser": "8.59.2",
        "class-transformer": "0.5.1",
        "class-validator": "0.15.1",
        "concurrently": "9.2.1",
        "eslint": "10.3.0",
        "eslint-plugin-perfectionist": "5.9.0",
        "eslint-plugin-unused-imports": "4.4.1",
        "express": "5.2.1",
        "globals": "17.6.0",
        "husky": "9.1.7",
        "ioredis": "5.10.1",
        "jest": "30.4.2",
        "joi": "18.2.1",
        "lint-staged": "17.0.4",
        "mongodb": "7.2.0",
        "mongoose": "9.6.2",
        "prettier": "3.8.3",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.2",
        "testcontainers": "11.14.0",
        "ts-jest": "29.4.9",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.2"
    },
    "packageManager": "npm@11.14.1"
}
