{
    "name": "nest-seed",
    "private": true,
    "workspaces": [
        "libs/*",
        "seeds/*"
    ],
    "scripts": {
        "build": "turbo run build --filter='./libs/*'",
        "clean": "turbo run clean",
        "lint": "turbo run lint --filter='./libs/*'",
        "test": "cd libs && NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
        "format": "prettier --write \"libs/*/src/**/*.ts\"",
        "changeset:add": "changeset add",
        "changeset:version": "changeset version",
        "changeset:publish": "npm run build && changeset publish"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@temporalio/testing": "^1.15.0",
        "@testcontainers/mongodb": "^11.13.0",
        "@testcontainers/nats": "^11.13.0",
        "eslint": "^10.1.0",
        "eslint-plugin-perfectionist": "^5.8.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "mongodb": "^7.1.1",
        "prettier": "^3.8.1",
        "testcontainers": "^11.13.0",
        "ts-jest": "^29.4.9",
        "turbo": "^2.9.3",
        "typescript-eslint": "^8.58.0"
    },
    "overrides": {
        "class-validator": "0.14.4",
        "lodash": "^4.18.0"
    },
    "packageManager": "npm@11.12.1"
}
