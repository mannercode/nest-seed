PROJECT_ID=nest-msa

REDIS_PASSWORD=redispass
REDIS_HOST1=host.docker.internal
REDIS_PORT1=6379
REDIS_HOST2=host.docker.internal
REDIS_PORT2=6380
REDIS_HOST3=host.docker.internal
REDIS_PORT3=6381
REDIS_HOST4=host.docker.internal
REDIS_PORT4=6382
REDIS_HOST5=host.docker.internal
REDIS_PORT5=6383
REDIS_HOST6=host.docker.internal
REDIS_PORT6=6384

MONGO_REPLICA_SET=mongo
MONGO_USERNAME=mongouser
MONGO_PASSWORD=mongopass
MONGO_DATABASE=mongodb
MONGO_HOST1=host.docker.internal
MONGO_PORT1=27017
MONGO_HOST2=host.docker.internal
MONGO_PORT2=27018
MONGO_HOST3=host.docker.internal
MONGO_PORT3=27019

NATS_CLUSTER=nats-cluster
NATS_HOST1=host.docker.internal
NATS_PORT1=4222
NATS_HOST2=host.docker.internal
NATS_PORT2=4223
NATS_HOST3=host.docker.internal
NATS_PORT3=4224

S3_ENDPOINT=http://host.docker.internal:9000
S3_REGION=us-east-1
S3_BUCKET=nest-bucket
S3_ACCESS_KEY_ID=admin
S3_SECRET_ACCESS_KEY=password
S3_FORCE_PATH_STYLE=true

HTTP_PORT=3000
HTTP_REQUEST_PAYLOAD_LIMIT=50mb
HTTP_PAGINATION_DEFAULT_SIZE=50

AUTH_ACCESS_SECRET=auth_access_secret_least_20
AUTH_ACCESS_TOKEN_EXPIRATION=30m
AUTH_REFRESH_SECRET=auth_refresh_secret_least_20
AUTH_REFRESH_TOKEN_EXPIRATION=7d

FILE_UPLOAD_MAX_FILE_SIZE_BYTES=5242880
FILE_UPLOAD_MAX_FILES_PER_UPLOAD=3
FILE_UPLOAD_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/json

LOG_DIRECTORY=./_output/logs
LOG_DAYS_TO_KEEP=3d
LOG_FILE_LEVEL=verbose
LOG_CONSOLE_LEVEL=info
