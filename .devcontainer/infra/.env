# Docker image tags — mirrored from Docker Hub to GHCR via
# .github/workflows/mirror-images.yaml.
#
# Pinning policy (3 tiers):
#   - Critical (data/runtime): minor pin. Conscious bump only.
#   - Boot tools (one-shot orchestration): major or floating pin.
#   - GUI (gui profile, opt-in): latest. Cron auto-tracks upstream.
#
# To bump: edit the tag here → trigger Mirror Docker Images workflow
# (workflow_dispatch) → commit. Mirror cron runs weekly to flow upstream
# patches into the floating tags automatically.

# --- Tier 1: Critical (data/runtime) ---
MINIO_IMAGE=minio/minio:latest
AWS_CLI_IMAGE=amazon/aws-cli:latest

MONGO_IMAGE=mongo:8.2
MONGO_EXPRESS_IMAGE=mongo-express:latest

NATS_IMAGE=nats:2.14-alpine

REDIS_IMAGE=redis:8.6-alpine
REDIS_INSIGHT_IMAGE=redis/redisinsight:latest
#  DEPRECATED This image is no longer maintained and will not receive updates.
# Docker Compose examples using the supported temporalio/server and temporalio/admin-tools images are available at: https://github.com/temporalio/samples-server/tree/main/compose⁠
TEMPORAL_IMAGE=temporalio/auto-setup:1.25
TEMPORAL_UI_IMAGE=temporalio/ui:latest
POSTGRES_IMAGE=postgres:17-alpine

DOCKER_IMAGE=docker:cli

# MongoDB
MONGO_REPLICA_SET=mongo
MONGO_USERNAME=mongouser
MONGO_PASSWORD=mongopass
MONGO_DATABASE=mongodb
MONGO_HOST1=host.docker.internal
MONGO_PORT1=27017
MONGO_HOST2=host.docker.internal
MONGO_PORT2=27018
MONGO_HOST3=host.docker.internal
MONGO_PORT3=27019

# Redis
REDIS_HOST1=host.docker.internal
REDIS_PORT1=6379
REDIS_HOST2=host.docker.internal
REDIS_PORT2=6380
REDIS_HOST3=host.docker.internal
REDIS_PORT3=6381

# MinIO (S3)
S3_ENDPOINT=http://host.docker.internal:9000
S3_REGION=us-east-1
S3_BUCKET=nest-bucket
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_FORCE_PATH_STYLE=true
S3_CONSOLE_ENDPOINT=http://host.docker.internal:9001

# NATS
NATS_HOST=host.docker.internal
NATS_PORT=4222
NATS_MONITORING_PORT=8222

# Temporal
TEMPORAL_HOST=host.docker.internal
TEMPORAL_PORT=7233
TEMPORAL_DB_PORT=5432
TEMPORAL_UI_PORT=8233
TEMPORAL_NAMESPACE=default
