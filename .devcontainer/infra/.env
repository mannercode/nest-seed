MINIO_IMAGE=minio/minio:latest
MONGO_IMAGE=mongo:8.2
NATS_IMAGE=nats:2.14-alpine
REDIS_IMAGE=redis:8.6-alpine
TEMPORAL_SERVER_IMAGE=temporalio/server:1.29
TEMPORAL_ADMIN_TOOLS_IMAGE=temporalio/admin-tools:1.29
TEMPORAL_POSTGRES_IMAGE=postgres:17-alpine

# MongoDB
# 토폴로지 (host/port/user/pass/replicaSet) 는 compose.mongo.yml 이 정의한다.
# 그 결과물인 connection URI 만 여기 둔다 — URI 가 바뀌면 compose.mongo.yml
# 의 hardcode 도 같이 바꿔야 한다 (devcontainer mongo 토폴로지는 거의 안 바뀜).
MONGO_URI=mongodb://mongouser:mongopass@host.docker.internal:27017,host.docker.internal:27018,host.docker.internal:27019/?replicaSet=mongo
MONGO_DATABASE=mongodb

# Redis
REDIS_HOST1=host.docker.internal
REDIS_PORT1=6379
REDIS_HOST2=host.docker.internal
REDIS_PORT2=6380
REDIS_HOST3=host.docker.internal
REDIS_PORT3=6381

# MinIO (S3)
S3_ENDPOINT=http://host.docker.internal:9000
S3_REGION=us-east-1
S3_BUCKET=bucket
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_FORCE_PATH_STYLE=true
S3_CONSOLE_ENDPOINT=http://host.docker.internal:9001

# NATS
NATS_HOST=host.docker.internal
NATS_PORT=4222
NATS_MONITORING_PORT=8222

# Temporal
TEMPORAL_HOST=host.docker.internal
TEMPORAL_PORT=7233
TEMPORAL_DB_PORT=5432
TEMPORAL_NAMESPACE=default
