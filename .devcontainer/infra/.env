# devcontainer 와 infra 컨테이너들이 호스트 docker 의 같은 네트워크
# (${COMPOSE_PROJECT_NAME}) 에 join 해 compose service name 으로 직접 도달한다.
# COMPOSE_PROJECT_NAME 은 devcontainer.json 의 containerEnv 가
# ${containerWorkspaceFolderBasename} 에서 자동 계산해 inject 하므로 여기
# 정의 안 한다 — 시드 프로젝트가 다른 이름으로 fork 됐을 때도 자동 적용.

MINIO_IMAGE=minio/minio:latest
MONGO_IMAGE=mongo:8.2
NATS_IMAGE=nats:2.14-alpine
REDIS_IMAGE=redis:8.6-alpine
TEMPORAL_SERVER_IMAGE=temporalio/server:1.29
TEMPORAL_ADMIN_TOOLS_IMAGE=temporalio/admin-tools:1.29
TEMPORAL_POSTGRES_IMAGE=postgres:17-alpine

# MongoDB
# replica set advertise host 도 같은 네트워크의 service name 으로 둬야 한다.
# rs.initiate 의 host 가 곧 client 가 다시 접속할 때 쓰는 주소이므로
# 컨테이너 안에서 풀리는 이름이어야 한다. compose.mongo.yml 의 hardcode 를
# 바꾸면 여기 URI 도 함께 바꿀 것.
MONGO_URI=mongodb://mongouser:mongopass@mongo1:27016,mongo2:27016,mongo3:27016/?replicaSet=mongo
MONGO_DATABASE=mongodb

# Redis - 같은 네트워크 안에서는 모두 6379. cluster announce port 도 6379 통일.
# (외부 호스트 포트 매핑은 디버깅용으로 compose 파일에 hardcode)
REDIS_HOST1=redis1
REDIS_PORT1=6379
REDIS_HOST2=redis2
REDIS_PORT2=6379
REDIS_HOST3=redis3
REDIS_PORT3=6379

# MinIO (S3)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=bucket
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_FORCE_PATH_STYLE=true
# console 은 호스트 브라우저에서 보는 용도라 호스트로 expose
S3_CONSOLE_ENDPOINT=http://localhost:9001

# NATS
NATS_HOST=nats
NATS_PORT=4222
NATS_MONITORING_PORT=8222

# Temporal
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_DB_PORT=5432
TEMPORAL_NAMESPACE=default
