# devcontainer 와 infra 컨테이너는 호스트 docker 의 같은 네트워크
# (`${COMPOSE_PROJECT_NAME}`) 에 함께 들어간다. 그래서 compose 서비스
# 이름으로 바로 닿는다.
# `COMPOSE_PROJECT_NAME` 은 여기 적지 않는다. devcontainer.json 의
# `containerEnv` 가 workspace 폴더 이름으로부터 자동 계산해 넣어 준다.
# 시드를 다른 이름으로 fork 해도 그대로 동작한다.

MINIO_IMAGE=minio/minio:latest
MONGO_IMAGE=mongo:8.2
NATS_IMAGE=nats:2.14-alpine
REDIS_IMAGE=redis:8.6-alpine
TEMPORAL_SERVER_IMAGE=temporalio/server:1.29
TEMPORAL_ADMIN_TOOLS_IMAGE=temporalio/admin-tools:1.29
TEMPORAL_POSTGRES_IMAGE=postgres:17-alpine

# MongoDB
# `rs.initiate` 가 등록하는 host 는 클라이언트가 다음에 접속할 때 다시 쓰는
# 주소다. 그래서 컨테이너 안에서 풀리는 이름이어야 하고, 같은 네트워크의
# service 이름을 그대로 둔다. `compose.mongo.yml` 안의 이름을 바꿀 때는
# 여기 URI 도 같이 바꾼다.
# 인증은 끄고 쓴다. 운영은 매니지드 서비스(DocumentDB 등)로 가므로 keyFile
# 흉내가 의미 없고, dev/test 환경에서는 보안 이득보다 운영 부담이 더 크다.
# URI 에 user/password 가 빠진 이유다.
MONGO_URI=mongodb://mongo1:27016,mongo2:27016,mongo3:27016/?replicaSet=mongo
MONGO_DATABASE=mongodb

# Redis — 같은 네트워크 안에서는 모두 6379 를 쓴다. cluster announce port 도
# 6379 로 통일한다. 외부 호스트 포트 매핑은 디버깅용으로 compose 파일 안에
# 따로 적어 둔다.
REDIS_HOST1=redis1
REDIS_PORT1=6379
REDIS_HOST2=redis2
REDIS_PORT2=6379
REDIS_HOST3=redis3
REDIS_PORT3=6379

# MinIO (S3)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=bucket
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_FORCE_PATH_STYLE=true
# MinIO console 은 호스트 브라우저로 보는 용도라서 호스트 포트로 노출한다.
S3_CONSOLE_ENDPOINT=http://localhost:9001

# NATS
NATS_HOST=nats
NATS_PORT=4222
NATS_MONITORING_PORT=8222

# Temporal
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_DB_PORT=5432
TEMPORAL_NAMESPACE=default
