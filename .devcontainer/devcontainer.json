{
    "name": "mannercode-workspace",
    "hostRequirements": { "cpus": 4, "memory": "16gb", "storage": "32gb" },
    "build": { "dockerfile": "Dockerfile", "context": "." },
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "privileged": true,
    "runArgs": [
        "--add-host",
        "host.docker.internal:127.0.0.1",
        "--name=${localEnv:USER:unknown}-${localWorkspaceFolderBasename}"
    ],
    "remoteUser": "node",
    "mounts": [
        "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind",
        "source=${localEnv:HOME}/.claude.json,target=/home/node/.claude.json,type=bind",
        "source=${localEnv:HOME}/.config/gh,target=/home/node/.config/gh,type=bind"
    ],
    "initializeCommand": {
        "prepare-mounts": "mkdir -p ${localEnv:HOME}/.claude ${localEnv:HOME}/.config/gh",
        "prepare-files": "touch ${localEnv:HOME}/.claude.json"
    },
    "postCreateCommand": {
        "clone-repos": "git clone https://github.com/mannercode/nest-msa.git nest-msa 2>/dev/null || true && git clone https://github.com/mannercode/nest-mono.git nest-mono 2>/dev/null || true && git clone https://github.com/mannercode/nest-libs.git nest-libs 2>/dev/null || true",
        "husky-msa": "cd nest-msa && husky",
        "husky-mono": "cd nest-mono && husky",
        "husky-nestlib": "cd nest-libs && husky",
        "ci-msa": "cd nest-msa && npm ci",
        "ci-mono": "cd nest-mono && npm ci",
        "ci-nestlib": "cd nest-libs && npm ci"
    },
    "postStartCommand": {
        "plantuml": "nohup bash -c 'java -jar /opt/plantuml.jar -picoweb:5020 >/tmp/plantuml.log &' >/dev/null"
    },
    "forwardPorts": [5010, 5020],
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "firsttris.vscode-jest-runner",
                "ms-vscode.live-server",
                "ms-azuretools.vscode-docker",
                "ms-azuretools.vscode-containers",
                "jebbs.plantuml",
                "esbenp.prettier-vscode",
                "mutantdino.resourcemonitor",
                "mkhl.shfmt",
                "anthropic.claude-code",
                "github.vscode-pull-request-github"
            ],
            "settings": {
                "files.watcherExclude": {
                    "**/.git/objects/**": true,
                    "**/.git/subtree-cache/**": true,
                    "**/node_modules/**": true,
                    "**/_output/**": true
                },
                "search.exclude": {
                    "**/node_modules/**": true,
                    "**/_output/**": true,
                    "**/dist/**": true
                },
                "files.exclude": { "**/node_modules/**": true },
                "files.associations": { "*.cfg": "shellscript" },
                "remote.autoForwardPorts": false,
                "remote.downloadExtensionsLocally": true,
                "prettier.enableDebugLogs": true,
                "livePreview.portNumber": 5010,
                "js/ts.tsc.autoDetect": "off",
                "js/ts.disableAutomaticTypeAcquisition": true,
                "js/ts.format.enable": false,
                "js/ts.validate.enable": false,
                "js/ts.updateImportsOnFileMove.enabled": "never",
                "editor.defaultFormatter": "esbenp.prettier-vscode",
                "[dockerfile]": { "editor.defaultFormatter": "ms-azuretools.vscode-containers" },
                "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
                "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
                "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
                "[dotenv]": { "editor.defaultFormatter": "mkhl.shfmt" },
                "[shellscript]": { "editor.defaultFormatter": "mkhl.shfmt" },
                "[ignore]": { "editor.defaultFormatter": "mkhl.shfmt" },
                "[properties]": { "editor.defaultFormatter": "mkhl.shfmt" },
                "[markdown]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
                "plantuml.server": "http://localhost:5020/",
                "plantuml.render": "PlantUMLServer",
                "githubPullRequests.pullBranch": "never",
                "githubPullRequests.createOnPublishBranch": "never",
                "githubPullRequests.fileListLayout": "flat",
                "githubIssues.queries": [
                    { "label": "My Issues", "query": "default" },
                    {
                        "label": "Created Issues",
                        "query": "author:${user} state:open repo:${owner}/${repository} sort:created-desc"
                    },
                    {
                        "label": "All Issues",
                        "query": "repo:${owner}/${repository} sort:updated-desc"
                    }
                ]
            }
        }
    }
}
