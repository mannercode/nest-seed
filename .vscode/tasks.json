{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "⇧⌘Build",
            "group": { "kind": "build", "isDefault": true },
            "type": "shell",
            "command": "npm run build"
        },
        {
            "label": "Tools",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "${input:toolCommand}"]
        },
        {
            "label": "Tests",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "${input:testCommand}"]
        },
        {
            "label": "Verify AtoZ",
            "type": "shell",
            "command": "npm run clean && npm run build && npm run lint && npm run test:unit && npm run test:e2e"
        }
    ],
    "inputs": [
        {
            "id": "toolCommand",
            "type": "pickString",
            "description": "tool",
            "options": [
                "npm run clean",
                "npm run lint",
                "npm run format",
                "ncu --deep",
                "ncu -u --deep"
            ]
        },
        {
            "id": "testCommand",
            "type": "pickString",
            "description": "test",
            "options": [
                "npm run test:unit",
                "npm run test:e2e",
                "npm run test:unit -w libs",
                "npm run test:unit -w apps/mono",
                "npm run test:unit -w apps/msa",
                "npm run test:e2e -w apps/mono",
                "npm run test:e2e -w apps/msa"
            ]
        }
    ]
}
