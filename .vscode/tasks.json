{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "verify:all",
            "dependsOn": ["all:clean", "all:build", "all:lint", "all:test:unit", "all:test:e2e"],
            "dependsOrder": "sequence"
        },
        { "label": "all:clean", "type": "shell", "command": "npm run clean" },
        {
            "label": "all:build",
            "group": { "kind": "build", "isDefault": true },
            "type": "shell",
            "command": "npm run build"
        },
        { "label": "all:lint", "type": "shell", "command": "npm run lint" },
        {
            "label": "all:test:unit",
            "group": { "kind": "test", "isDefault": true },
            "type": "shell",
            "command": "npm run test:unit"
        },
        { "label": "all:test:e2e", "type": "shell", "command": "npm run test:e2e" },
        { "label": "mono:test:unit", "type": "shell", "command": "npm run test:unit -w apps/mono" },
        { "label": "mono:test:e2e", "type": "shell", "command": "npm run test:e2e -w apps/mono" },
        { "label": "msa:test:unit", "type": "shell", "command": "npm run test:unit -w apps/msa" },
        { "label": "msa:test:e2e", "type": "shell", "command": "npm run test:e2e -w apps/msa" }
    ]
}
