{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Tests",
            "detail": "run npm test with TEST_ROOT",
            "group": { "kind": "test", "isDefault": true },
            "type": "shell",
            "options": { "env": { "TEST_ROOT": "${input:TestRoots}" } },
            "command": "npm test"
        },
        {
            "label": "Repeat Tests",
            "detail": "repeat npm test with TEST_ROOT",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "set -e; export TEST_ROOT=${input:TestRoots}; for ((i=1; i<=${input:RepeatCount}; i++)); do echo \"[Run $i/${input:RepeatCount}]\"; npm test; done; echo \"Done. ${input:RepeatCount} run(s) finished.\""
            ]
        },
        {
            "label": "Run E2E Tests",
            "detail": "npm run test:e2e",
            "type": "shell",
            "command": "npm run test:e2e"
        }
    ],
    "inputs": [
        {
            "id": "TestRoots",
            "type": "pickString",
            "options": ["src", "src/apps", "src/libs/common"],
            "description": "Select the source root."
        },
        {
            "id": "RepeatCount",
            "type": "promptString",
            "default": "100",
            "description": "How many times to repeat npm test."
        }
    ]
}
