{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "packages:build",
            "group": { "kind": "build", "isDefault": true },
            "type": "shell",
            "command": "npm run build"
        },
        { "label": "packages:lint", "type": "shell", "command": "npm run lint" },
        {
            "label": "packages:test",
            "group": { "kind": "test", "isDefault": true },
            "type": "shell",
            "command": "npm test"
        },
        { "label": "msa:lint", "type": "shell", "command": "npm --prefix templates/msa run lint" },
        {
            "label": "msa:test:unit",
            "type": "shell",
            "command": "npm --prefix templates/msa run test:unit"
        },
        {
            "label": "msa:test:e2e",
            "type": "shell",
            "command": "npm --prefix templates/msa run test:e2e"
        },
        {
            "label": "mono:lint",
            "type": "shell",
            "command": "npm --prefix templates/mono run lint"
        },
        {
            "label": "mono:test:unit",
            "type": "shell",
            "command": "npm --prefix templates/mono run test:unit"
        },
        {
            "label": "mono:test:e2e",
            "type": "shell",
            "command": "npm --prefix templates/mono run test:e2e"
        }
    ]
}
