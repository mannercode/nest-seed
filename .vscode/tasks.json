{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "group": { "kind": "build", "isDefault": true },
            "type": "shell",
            "command": "npm run build"
        },
        { "label": "lint", "type": "shell", "command": "npm run lint" },
        {
            "label": "test",
            "group": { "kind": "test", "isDefault": true },
            "type": "shell",
            "command": "npm test"
        },
        {
            "label": "test:templates",
            "type": "shell",
            "command": "npm --prefix templates/msa run test:unit && npm --prefix templates/mono run test:unit"
        }
    ]
}
