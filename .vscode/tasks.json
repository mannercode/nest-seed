{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Test",
            "detail": "Run the selected test suites",
            "type": "shell",
            "command": "bash scripts/run-test.sh ${input:tests} 1"
        },
        {
            "label": "CLI",
            "detail": "Run the CLI tool",
            "type": "shell",
            "command": "bash scripts/run-cli.sh",
            "runOptions": {
                "instanceLimit": 99
            }
        },
        {
            "label": "Lint",
            "detail": "Run ESLint and Prettier",
            "type": "shell",
            "command": "npm run lint"
        },
        {
            "label": "Workspace Cleanup",
            "detail": "Reset the development environment and remove all data",
            "type": "shell",
            "command": "bash scripts/workspace-cleanup.sh"
        }
    ],
    "inputs": [
        {
            "id": "tests",
            "type": "pickString",
            "options": [
                "all",
                "apps",
                "common"
            ],
            "description": "Select a test suite to run."
        }
    ]
}
