{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "*** VERIFY ALL ***",
            "dependsOn": ["all:clean", "all:build", "all:lint", "all:test:unit"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        { "label": "all:clean", "type": "shell", "command": "npm run clean" },
        {
            "label": "all:build",
            "group": { "kind": "build", "isDefault": true },
            "type": "shell",
            "command": "npm run build"
        },
        { "label": "all:lint", "type": "shell", "command": "npm run lint" },
        {
            "label": "all:test:unit",
            "group": { "kind": "test", "isDefault": true },
            "type": "shell",
            "command": "npm run test:unit"
        },
        {
            "label": "mono:test:unit",
            "group": { "kind": "test" },
            "type": "shell",
            "command": "npm run test:unit -w apps/mono"
        },
        {
            "label": "mono:test:e2e",
            "group": { "kind": "test" },
            "type": "shell",
            "command": "npm run test:e2e -w apps/mono"
        },
        {
            "label": "msa:test:unit",
            "group": { "kind": "test" },
            "type": "shell",
            "command": "npm run test:unit -w apps/msa"
        },
        {
            "label": "msa:test:e2e",
            "group": { "kind": "test" },
            "type": "shell",
            "command": "npm run test:e2e -w apps/msa"
        }
    ]
}
