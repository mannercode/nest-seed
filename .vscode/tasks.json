{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Tools",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "${input:toolCommand}"]
        },
        {
            "label": "Tests",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "${input:testCommand}"]
        },
        {
            "label": "Claude (tmux)",
            "type": "shell",
            "command": "tmux new -As work claude",
            "presentation": { "reveal": "always", "panel": "dedicated", "focus": true },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "toolCommand",
            "type": "pickString",
            "description": "tool",
            "options": [
                "npm run build",
                "npm run clean",
                "npm run lint",
                "npm run format",
                "ncu --deep",
                "ncu --deep -u && npm install"
            ]
        },
        {
            "id": "testCommand",
            "type": "pickString",
            "description": "test",
            "options": [
                "npm run dev",
                "npm test",
                "npm test -w apps",
                "npm run atoz",
                "npm run atoz -w apps"
            ]
        }
    ]
}
