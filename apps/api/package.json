{
    "name": "api",
    "version": "0.0.2",
    "private": true,
    "scripts": {
        "start": "node _output/dist/index.js",
        "format": "eslint src/ scripts/ --fix && prettier --write src/ scripts/",
        "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.jest.json && eslint src/ scripts/ --max-warnings=0 && prettier --check src/ scripts/",
        "build": "nest build -b webpack && npm run bundle-workflows",
        "bundle-workflows": "ts-node --transpile-only scripts/bundle-workflows.ts",
        "predev": "free-port 3000 && npm run bundle-workflows",
        "dev": "nest start --watch",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
        "atoz": "npm run lint && npm test"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "3.1053.0",
        "@aws-sdk/s3-presigned-post": "3.1053.0",
        "@aws-sdk/s3-request-presigner": "3.1053.0",
        "@mannercode/common": "*",
        "@mannercode/temporal-sandbox": "*",
        "@nestjs/common": "11.1.23",
        "@nestjs/config": "4.0.4",
        "@nestjs/core": "11.1.23",
        "@nestjs/jwt": "11.0.2",
        "@nestjs/mapped-types": "2.1.1",
        "@nestjs/mongoose": "11.0.4",
        "@nestjs/platform-express": "11.1.23",
        "@nestjs/schedule": "6.1.3",
        "@nestjs/terminus": "11.1.1",
        "@temporalio/activity": "1.17.1",
        "@temporalio/client": "1.17.1",
        "@temporalio/worker": "1.17.1",
        "@temporalio/workflow": "1.17.1",
        "bcrypt": "6.0.0",
        "class-transformer": "0.5.1",
        "class-validator": "0.15.1",
        "compression": "1.8.1",
        "express": "5.2.1",
        "ioredis": "5.10.1",
        "joi": "18.2.1",
        "mongoose": "9.6.2",
        "nats": "2.29.3",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.2"
    },
    "devDependencies": {
        "@mannercode/dev-tools": "*",
        "@mannercode/jest-helpers": "*",
        "@mannercode/testing": "*",
        "@nestjs/cli": "11.0.21",
        "@nestjs/schematics": "11.1.0",
        "@nestjs/testing": "11.1.23",
        "@types/bcrypt": "6.0.0",
        "@types/compression": "1.8.1",
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/node": "24",
        "eslint": "10.4.0",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-allowed-dependencies": "2.2.0",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-jest": "29.15.2",
        "eslint-plugin-perfectionist": "5.9.0",
        "eslint-plugin-unused-imports": "4.4.1",
        "globals": "17.6.0",
        "jest": "30.4.2",
        "prettier": "3.8.3",
        "ts-jest": "29.4.11",
        "ts-loader": "9.5.7",
        "ts-node": "10.9.2",
        "tsconfig-paths": "4.2.0",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.4"
    }
}
