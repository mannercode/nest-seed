# run.sh가 source 하므로 bash fallback 문법 사용 가능. 외부 호출자가
# SERVER_URL을 export 해두면 그 값이 우선 — deploy/test.sh가 dod 환경에서
# nginx service name (http://nginx:80) 으로 override 합니다.
SERVER_URL="${SERVER_URL:-http://localhost:3000}"

# e2e 폴더는 문서를 겸하므로 이식성을 우선합니다.
# SHA-256도구는 OS마다 다를 수 있어 미리 계산한 값도 함께 둡니다.
ASSET_IMAGE_PATH=./assets/image.png
ASSET_IMAGE_ORIGINAL_NAME=image.png
ASSET_IMAGE_SIZE=170550
ASSET_IMAGE_SHA256_BASE64=d5l1XdGa5zgerERd5V5xMR0X0mbMoZvJL1liTH1to2A=
