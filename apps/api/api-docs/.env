# run.sh가 source 하므로 bash 기본값 문법을 사용할 수 있습니다. 외부 호출자가
# SERVER_URL을 export하면 그 값을 우선합니다. deploy/test.sh는 Docker 네트워크 안에서
# nginx 서비스 이름(http://nginx:80)을 넘깁니다.
SERVER_URL="${SERVER_URL:-http://localhost:3000}"

# API 문서는 실행 가능한 문서이므로 이식성을 우선합니다.
# SHA-256 도구는 OS마다 달라질 수 있어 미리 계산한 값도 함께 둡니다.
ASSET_IMAGE_PATH=./assets/image.png
ASSET_IMAGE_ORIGINAL_NAME=image.png
ASSET_IMAGE_SIZE=170550
ASSET_IMAGE_SHA256_BASE64=d5l1XdGa5zgerERd5V5xMR0X0mbMoZvJL1liTH1to2A=
