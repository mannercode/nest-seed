{
    "name": "nest-msa",
    "version": "0.0.2",
    "private": true,
    "comments": {
        "scripts": {
            "TARGET_APP": [
                "TARGET_APP must match a Nest project key defined in nest-cli.json.",
                "Example: TARGET_APP=gateway npm run build"
            ]
        }
    },
    "scripts": {
        "start": "node _output/dist/${TARGET_APP}/index.js",
        "build": "nest build ${TARGET_APP} -b webpack",
        "dev": "nest start ${TARGET_APP} --watch",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --no-cache --coverage",
        "test:e2e": "npm run apps:reset && bash tests/e2e/run-all.sh && npm run apps:down",
        "format": "eslint src/ --fix && prettier --write src/",
        "lint": "tsc -p tsconfig.json --noEmit && eslint src/ --max-warnings=0 && prettier --check src/",
        "apps:reset": "npm run apps:down && npm run apps:up && npm run apps:wait",
        "apps:down": "docker compose down -v -t 0",
        "apps:up": "  docker compose up -d --build",
        "apps:wait": "docker wait apps-setup && docker rm apps-setup"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1024.0",
        "@aws-sdk/s3-presigned-post": "^3.1024.0",
        "@aws-sdk/s3-request-presigner": "^3.1024.0",
        "@mannercode/common": "^2.0.2",
        "@mannercode/microservices": "^2.0.2",
        "@nestjs/common": "^11.1.18",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.18",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/mapped-types": "^2.1.1",
        "@nestjs/microservices": "^11.1.18",
        "@nestjs/mongoose": "^11.0.4",
        "@nestjs/platform-express": "^11.1.18",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/terminus": "^11.1.1",
        "@temporalio/activity": "^1.15.0",
        "@temporalio/client": "^1.15.0",
        "@temporalio/worker": "^1.15.0",
        "@temporalio/workflow": "^1.15.0",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.4",
        "compression": "^1.8.1",
        "express": "^5.2.1",
        "ioredis": "^5.10.1",
        "joi": "^18.1.2",
        "mongoose": "^9.4.1",
        "mongoose-lean-virtuals": "^2.1.0",
        "nats": "^2.29.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@mannercode/testing": "^2.0.2",
        "@nestjs/cli": "^11.0.17",
        "@nestjs/schematics": "^11.0.10",
        "@nestjs/testing": "^11.1.18",
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^24",
        "eslint": "^10.2.0",
        "eslint-plugin-allowed-dependencies": "^2.1.0",
        "eslint-plugin-jest": "^29.15.1",
        "eslint-plugin-perfectionist": "^5.8.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.4.0",
        "jest": "^30.3.0",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.9",
        "ts-loader": "^9.5.7",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0"
    },
    "overrides": {
        "lodash": "^4.18.0"
    }
}
