{
    "name": "@mannercode/testing",
    "version": "2.0.3",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "clean": "rm -rf dist *.tsbuildinfo",
        "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --no-cache --coverage",
        "lint": "tsc --noEmit && eslint src/ --max-warnings=0 && prettier --check src/",
        "format": "eslint src/ --fix && prettier --write src/"
    },
    "publishConfig": {
        "access": "public"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mannercode/nest-seed.git",
        "directory": "libs/testing"
    },
    "dependencies": {
        "superagent": "^10.3.0"
    },
    "peerDependencies": {
        "@mannercode/common": "^2.0.3",
        "@nestjs/common": "^11.0.0",
        "@nestjs/testing": "^11.0.0"
    }
}
