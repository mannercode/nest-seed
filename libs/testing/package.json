{
    "name": "@mannercode/testing",
    "version": "0.0.1",
    "private": true,
    "main": "_output/dist/index.js",
    "types": "_output/dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
        "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.jest.json && eslint src/ --max-warnings=0 && prettier --check src/",
        "format": "eslint src/ --fix && prettier --write src/",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
        "atoz": "npm run build && npm run lint && npm test"
    },
    "dependencies": {
        "superagent": "10.3.0"
    },
    "peerDependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/testing": "^11.0.0"
    },
    "devDependencies": {
        "ts-jest": "^29.4.11"
    }
}
