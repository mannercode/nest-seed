{
    "name": "@mannercode/testing",
    "main": "_output/dist/index.js",
    "types": "_output/dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "clean": "rm -rf _output",
        "lint": "tsc --noEmit && eslint src/ --max-warnings=0 && prettier --check src/",
        "format": "eslint src/ --fix && prettier --write src/",
        "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --no-cache",
        "test:e2e": "echo 'skipped (no e2e tests)'"
    },
    "dependencies": {
        "superagent": "10.3.0"
    },
    "peerDependencies": {
        "@mannercode/common": "*",
        "@nestjs/common": "^11.0.0",
        "@nestjs/testing": "^11.0.0"
    }
}
