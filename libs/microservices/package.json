{
    "name": "@mannercode/microservices",
    "version": "2.0.3",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "clean": "rm -rf dist *.tsbuildinfo _output",
        "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --no-cache --coverage",
        "lint": "tsc --noEmit && eslint src/ --max-warnings=0 && prettier --check src/",
        "format": "eslint src/ --fix && prettier --write src/"
    },
    "peerDependencies": {
        "@mannercode/common": "*",
        "@nestjs/common": "^11.0.0",
        "@nestjs/microservices": "^11.0.0",
        "@temporalio/client": "^1.15.0",
        "@temporalio/worker": "^1.15.0",
        "rxjs": "^7.0.0"
    },
    "devDependencies": {}
}
