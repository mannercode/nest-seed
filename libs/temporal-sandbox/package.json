{
    "name": "@mannercode/temporal-sandbox",
    "main": "_output/dist/index.js",
    "types": "_output/dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
        "clean": "jest --clearCache",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
        "lint": "tsc --noEmit && eslint src/ --max-warnings=0 && prettier --check src/",
        "format": "eslint src/ --fix && prettier --write src/",
        "atoz": "npm run build && npm run lint && npm test"
    },
    "peerDependencies": {
        "@temporalio/common": "^1.17.0",
        "@temporalio/workflow": "^1.17.0"
    },
    "devDependencies": {
        "@mannercode/dev-tools": "*",
        "@types/jest": "30.0.0",
        "@types/node": "24",
        "eslint": "10.3.0",
        "eslint-plugin-allowed-dependencies": "2.2.0",
        "eslint-plugin-jest": "29.15.2",
        "eslint-plugin-perfectionist": "5.9.0",
        "eslint-plugin-unused-imports": "4.4.1",
        "globals": "17.6.0",
        "jest": "30.4.2",
        "prettier": "3.8.3",
        "ts-jest": "29.4.9",
        "ts-node": "10.9.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.2"
    }
}
