{
    "name": "@mannercode/temporal-sandbox",
    "version": "0.0.1",
    "private": true,
    "main": "_output/dist/index.js",
    "types": "_output/dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
        "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.jest.json && eslint src/ --max-warnings=0 && prettier --check src/",
        "format": "eslint src/ --fix && prettier --write src/",
        "atoz": "npm run build && npm run lint && npm test"
    },
    "peerDependencies": {
        "@temporalio/common": "^1.17.0",
        "@temporalio/workflow": "^1.18.1"
    },
    "devDependencies": {
        "@types/jest": "30.0.0",
        "@types/node": "24",
        "eslint": "10.5.0",
        "eslint-plugin-allowed-dependencies": "2.2.0",
        "eslint-plugin-jest": "29.15.2",
        "eslint-plugin-perfectionist": "5.9.1",
        "eslint-plugin-unused-imports": "4.4.1",
        "globals": "17.6.0",
        "jest": "30.4.2",
        "prettier": "3.8.4",
        "ts-jest": "29.4.11",
        "ts-node": "10.9.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.61.1"
    }
}
