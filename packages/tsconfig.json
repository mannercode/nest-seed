{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0",
        "target": "ESNext",
        "lib": ["ESNext"],
        "types": ["node", "jest"],

        "strict": true,
        "strictPropertyInitialization": false,

        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "declaration": true,
        "declarationMap": true,

        "sourceMap": true,

        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,

        "resolveJsonModule": true,
        "esModuleInterop": true,

        "skipLibCheck": true,

        "baseUrl": ".",
        "paths": {
            "@mannercode/common": ["common/src"],
            "@mannercode/microservice": ["microservice/src"],
            "@mannercode/testing": ["testing/src"]
        }
    },
    "include": ["*/src/**/*"]
}
